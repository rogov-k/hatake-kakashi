{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "builds": [
    { "src": "dist/static/*", "use": "@vercel/static" },
    { "src": "dist/api/**/*", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/dist/static/index.html" },
    { "src": "/favicon.ico", "dest": "/dist/static/favicon.ico" },

    { "src": "/chess", "dest": "/dist/api/chess/index.js" },
    { "src": "/api/echo", "dest": "/dist/api/echo/index.js" }
  ]
}
