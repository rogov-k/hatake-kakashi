{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "buildCommand": "npm run build",
  "builds": [
    { "src": "dist/**/*", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/dist/chess/index.js" },
    { "src": "/echo", "dest": "/dist/echo/index.js" }
  ]
}
